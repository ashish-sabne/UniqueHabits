@page "/add-habit"
@using UnqiueHabits.Contracts;
@inject HabitService HabitService
@inject NavigationManager Navigation

<PageTitle>Add Habit</PageTitle>

<h3>Add Habit</h3>

<Steps @ref="stepsRef" @bind-SelectedStep="@selectedStep" NavigationAllowed="NavigationAllowed">
    <Items>
        <Step Name="Start">
            <Marker>
                <Icon Name="IconName.BirthdayCake"></Icon>
            </Marker>
            <Caption>Start a Habit</Caption>
        </Step>
        <Step Name="Details">
            <Marker>
                <Icon Name="IconName.List"></Icon>
            </Marker>
            <Caption>Enter Habit Details</Caption>
        </Step>
        <Step Name="Review">
            <Marker>
                <Icon Name="IconName.CheckDouble"></Icon>
            </Marker>
            <Caption>Review Habit Details</Caption>
        </Step>
    </Items>
    <Content>
        <StepPanel Name="Start">
            <HabitStart OnSubmit="HabitCreated" OnCancel="CancelHabit"></HabitStart>
        </StepPanel>
        <StepPanel Name="Details">
            @if (habitStarted)
            {
                <HabitDetails OnSubmit="HabitDetailsAdded" OnCancel="CancelHabit" OnPrevious="GoToPreviousStep"></HabitDetails>
            }
        </StepPanel>
        <StepPanel Name="Review">
            @if (habitDetailsAdded)
            {
                <ReviewHabit OnSubmit="SubmitHabit" OnCancel="CancelHabit" OnPrevious="GoToPreviousStep"></ReviewHabit>
            }
        </StepPanel>
    </Content>
</Steps>

@code {
    private HabitModel habit = HabitState.CurrentHabit;

    private Steps stepsRef;
    private string selectedStep = "Start";

    bool habitStarted = false;
    bool habitDetailsAdded = false;

    protected override void OnInitialized()
    {
        HabitState.Clear();
        base.OnInitialized();
    }

    async Task HabitCreated()
    {
        /*if (habit.ImplementationDetails == null)
            habit.AddImplementationDetails();*/
        habitStarted = true;
        await stepsRef.NextStep();
    }

    async Task HabitDetailsAdded()
    {
        habitDetailsAdded = true;
        await stepsRef.NextStep();
    }

    async Task GoToPreviousStep()
    {
        await stepsRef.PreviousStep();
    }

    void CancelHabit()
    {
        HabitState.Clear();
        GoToHomePage();
    }

    void SubmitHabit()
    {
        //HabitService.AddHabit(habit);
        CancelHabit();
    }

    void GoToHomePage()
    {
        Navigation.NavigateTo("/");
    }

    private bool NavigationAllowed(StepNavigationContext context)
    {
        switch (context.NextStepIndex)
        {
            case 1:
                return true;
            case 2:
                return habitStarted;
            case 3:
                return context.CurrentStepIndex < 3 && habitDetailsAdded;
            default:
                return true;
        }
    }
}
