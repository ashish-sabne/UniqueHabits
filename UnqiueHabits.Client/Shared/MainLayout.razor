@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (AuthState.CurrentUser == null)
            {
                <a href="/register">Register</a>
                <a href="/login" class="pl-2">Login</a>
            }
            else
            {
                <EditForm Model="@temp" OnValidSubmit="Logout">
                    <Field ColumnSize="ColumnSize.IsFull">
                        <Button Color="Color.Link" Type="ButtonType.Submit" Class="btn-link">Logout</Button>
                    </Field>
                </EditForm>
            }
        </div>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    bool temp = true;
    void Logout()
    {
        AuthState.Clear();
        Navigation.NavigateTo("/login");
    }
}