@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu ShowAuthenticatedMenuItems="IsAuthenticated" />
    </div>

    <main>
        <div class="top-row px-4">
            @if (IsAuthenticated)
            {
                if (AuthState.CurrentUser != null)
                {
                    <Badge>Hello, @AuthState.CurrentUser.Name</Badge>
                }
                <Blazorise.Link To="javascript::void(0)" Clicked="Logout">Log Out</Blazorise.Link>
            }
            else
            {

                <Blazorise.Link To="/register">Register</Blazorise.Link>
                <Blazorise.Link To="/login" class="pl-2">Login</Blazorise.Link>
            }
        </div>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {

    [Inject] AuthState AuthState { get; set; }

    bool IsAuthenticated
    {
        get
        {
            var isAuthenticated = AuthState?.IsAuthenticated() ?? false;
            return isAuthenticated;
        }
    }
    protected override void OnInitialized()
    {
        if (!IsAuthenticated)
        {
            Navigation.NavigateTo($"/login?ReturnUrl={Navigation.ToBaseRelativePath(Navigation.Uri)}");
        }

        base.OnInitialized();
    }

    async Task Logout()
    {
        await AuthState.ClearAsync();
        Navigation.NavigateTo("/login");
    }
}