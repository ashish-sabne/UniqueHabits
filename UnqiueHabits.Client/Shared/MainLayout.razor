@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <Layout Sider>
        <LayoutSider>
            <LayoutSiderContent>
                <NavMenu ShowAuthenticatedMenuItems="IsAuthenticated" />
            </LayoutSiderContent>
        </LayoutSider>
        <Layout>
            <LayoutHeader Fixed>
                <Bar Mode="BarMode.Horizontal" Breakpoint="Breakpoint.Desktop" Background="Background.Light" 
                    ThemeContrast="ThemeContrast.Light">
                    <BarToggler />
                    <BarMenu>
                        <BarEnd>
                            @if (IsAuthenticated)
                            {
                                if (AuthState.CurrentUser != null)
                                {
                                    <BarItem>
                                        <BarLabel>Hello, @AuthState.CurrentUser.Name</BarLabel>
                                    </BarItem>
                                    <BarItem>
                                        <Blazorise.Link To="javascript::void(0)" Clicked="Logout" 
                                            Padding="Padding.Is2">
                                            Log out
                                        </Blazorise.Link>
                                    </BarItem>
                                    
                                }
                            }
                            else
                            {
                                <BarItem>
                                    <Blazorise.Link To="/register">Register</Blazorise.Link>
                                    <Blazorise.Link To="/login" Padding="Padding.Is2">Log in</Blazorise.Link>
                                </BarItem>
                            }
                        </BarEnd>
                    </BarMenu>
                </Bar>
                @* 
                    <div class="top-row px-4">
                    @if (IsAuthenticated)
                    {
                        if (AuthState.CurrentUser != null)
                        {
                            <Badge>Hello, @AuthState.CurrentUser.Name</Badge>
                        }
                        <Blazorise.Link To="javascript::void(0)" Clicked="Logout">Log Out</Blazorise.Link>
                    }
                    else
                    {

                        <Blazorise.Link To="/register">Register</Blazorise.Link>
                        <Blazorise.Link To="/login" class="pl-2">Login</Blazorise.Link>
                    }
                </div> *@
            </LayoutHeader>
            <LayoutContent>
                <article class="content px-4">
                    @Body
                </article>
            </LayoutContent>
        </Layout>
    </Layout>
</div>

@code {

    [Inject] AuthState AuthState { get; set; }

    bool IsAuthenticated
    {
        get
        {
            var isAuthenticated = AuthState?.IsAuthenticated() ?? false;
            return isAuthenticated;
        }
    }
    protected override void OnInitialized()
    {
        if (!IsAuthenticated)
        {
            Navigation.NavigateTo($"/login?ReturnUrl={Navigation.ToBaseRelativePath(Navigation.Uri)}");
        }

        base.OnInitialized();
    }

    async Task Logout()
    {
        await AuthState.ClearAsync();
        Navigation.NavigateTo("/login");
    }
}