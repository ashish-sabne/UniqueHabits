@if (IsEditable)
{
    <HabitStepForm OnSubmit="AddStep"></HabitStepForm>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <Paragraph TextColor="TextColor.Warning">@errorMessage</Paragraph>
    }
}

@if (Steps != null)
{
    <DropContainer @ref="dropContainer" TItem="ImplementationStep" Items="@Steps" ItemsFilter="(i,s) => {return true;}" ItemDropped="@ItemDropped" Flex="Flex.Wrap.Grow.Is1">
        <ChildContent>
            <DropZone @ref="dropZone" AllowReorder="IsEditable" DropAllowed="(i) => IsEditable" TItem="ImplementationStep" Name="Steps"
                      Border="Border.Rounded" Background="Background.Light" Padding="Padding.Is3" Margin="Margin.Is3" Flex="Flex.Grow.Is1">
            </DropZone>
        </ChildContent>
        <ItemTemplate>
            <Card Shadow="Shadow.Default" Margin="Margin.Is3.OnY">
                <CardBody>
                   <HabitStep Step="@context" ShowButtons="IsEditable" OnRemove="ConfirmRemoveStep" />
                </CardBody>
            </Card>
        </ItemTemplate>
    </DropContainer>

    @if (confirmModalId != Guid.Empty)
    {
        <ConfirmModal ConfirmTitle="Remove Step" ConfirmText="remove this step?" OnConfirm="() => RemoveStep(confirmModalId)" OnCancel="CancelRemoveStep"></ConfirmModal>
    }

    if (!Steps.Any())
    {
        <Paragraph TextColor="TextColor.Danger">
            No steps added
        </Paragraph>
    }
}



@code {
    DropContainer<ImplementationStep> dropContainer;
    DropZone<ImplementationStep> dropZone;

    [Parameter]
    public List<ImplementationStep> Steps { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public EventCallback<List<ImplementationStep>> OnUpdate { get; set; }

    Guid confirmModalId = Guid.Empty;

    private Task ItemDropped(DraggableDroppedEventArgs<ImplementationStep> args)
    {
        var targetSequence = args.IndexInZone;
        var targetItem = args.Item;
        RearrangeSteps(targetSequence, targetItem);
        return Task.CompletedTask;
    }

    string errorMessage = "";

    void RearrangeSteps(int targetSequence, ImplementationStep targetItem)
    {
        var newSteps = new List<ImplementationStep>();

        newSteps.AddRange(Steps.Where(s => s.Id != targetItem.Id).OrderBy(s => s.Sequence));
        newSteps.Insert(targetSequence, targetItem);

        Steps = newSteps;
        ReorderSteps();
    }

    void ReorderSteps()
    {
        for (int index = 0; index < Steps.Count; index++)
        {
            Steps[index].Sequence = index + 1;
        }
        OnUpdate.InvokeAsync(Steps);
        dropContainer.Refresh();
    }

    void AddStep(string newStepText)
    {
        if (!string.IsNullOrEmpty(newStepText) && ValidateNewStep(newStepText))
        {

            int newSequence = Steps.Count;
            Steps.Add(new ImplementationStep
                {
                    Id = Guid.NewGuid(),
                    Step = newStepText,
                    Sequence = newSequence
                });
            ReorderSteps();
        }
    }

    void ConfirmRemoveStep(Guid stepId)
    {
        confirmModalId = stepId;
    }

    void CancelRemoveStep()
    {
        confirmModalId = Guid.Empty;
    }

    void RemoveStep(Guid stepId)
    {
        CancelRemoveStep();
        var step = Steps.FirstOrDefault(s => s.Id == stepId);
        if (step != null)
        {
            Steps.Remove(step);
            ReorderSteps();
        }
    }

    bool ValidateNewStep(string newStepText)
    {
        if (Steps.Any(s => s.Step.Equals(newStepText, StringComparison.CurrentCultureIgnoreCase)))
        {
            errorMessage = "You have already recorded this step";
            return false;
        }
        else
        {
            errorMessage = string.Empty;
            return true;
        }

    }
}
